@{
    var autenticado = Context.Session.GetString("Autenticado");
    var nombre = Context.Session.GetString("Nombre");
    var consecutivoRol = Context.Session.GetInt32("ConsecutivoRol");
    var nombreRol = Context.Session.GetString("NombreRol");
}
@using FerreteriaWeb.Helpers
@using FerreteriaWeb.Models

@{
    var carrito = Context.Session.GetObject<CarritoModel>("Carrito");
    var cantidadCarrito = carrito?.Items.Sum(x => x.Cantidad) ?? 0;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ferretería ProAva</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FerreteriaWeb.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("PageStyles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow mb-3 py-2"
             style="background-color:#66696E;">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-uppercase d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="bg-warning text-dark px-2 py-1 rounded me-1"><i class="bi bi-tools"></i> FERRE</span>
                    <span class="text-white">PROAVA</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i> Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacto" asp-action="Crear">Contacto</a>
                        </li>
                        @if (Context.Session.GetString("Autenticado") == "1")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Contacto" asp-action="Index">Soporte</a>
                            </li>
                        }

                        @if (autenticado == "1" && consecutivoRol == 1)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-warning fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Administración
                                </a>
                                <ul class="dropdown-menu shadow" aria-labelledby="adminDropdown">
                                    <li>
                                        <a class="dropdown-item fw-semibold text-primary" asp-controller="Admin" asp-action="Index">
                                            <i class="bi bi-speedometer2 me-2"></i> Panel Principal
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Usuario" asp-action="ConsultarUsuarios">
                                            <i class="bi bi-people-fill me-2 text-info"></i> Gestión de Usuarios
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Producto" asp-action="ConsultarProductosAdmin">
                                            <i class="bi bi-tools me-2 text-success"></i> Gestión de Productos
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Producto" asp-action="ConsultarCategorias">
                                            <i class="bi bi-tags-fill me-2 text-warning"></i> Gestión de Categorías
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (autenticado == "1" && consecutivoRol == 4)
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link position-relative text-white"
                                   asp-controller="Carrito"
                                   asp-action="Index"
                                   title="Carrito">

                                    <i class="bi bi-cart3 fs-4"></i>

                                    @if (cantidadCarrito > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @cantidadCarrito
                                        </span>
                                    }
                                </a>
                            </li>
                        }
                        @if (autenticado == "1")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 text-white" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-warning text-dark fw-bold d-flex align-items-center justify-content-center" style="width:34px;height:34px;">
                                        @(string.IsNullOrEmpty(nombre) ? "U" : nombre.Substring(0, 1).ToUpper())
                                    </div>
                                    <span>@nombre</span>
                                    <small class="badge bg-primary">@(string.IsNullOrEmpty(nombreRol) ? "Usuario" : nombreRol)</small>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userMenu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Usuario" asp-action="Configuracion">
                                            <i class="bi bi-gear me-2"></i> Ajustes / Mi Cuenta
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Salir">
                                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm px-3" asp-controller="Auth" asp-action="LoginBasic">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning btn-sm px-3 fw-bold" asp-controller="Auth" asp-action="RegisterBasic">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5 py-3">
        <div class="container-fluid text-center">
            &copy; 2026 - Ferretería ProAva - Sistema de Gestión Ferretera
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
