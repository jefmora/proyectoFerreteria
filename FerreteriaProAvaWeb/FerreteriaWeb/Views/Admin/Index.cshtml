@{
    ViewData["Title"] = "Panel de Administración";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 bg-dark text-white p-4 rounded shadow-sm">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-speedometer2 text-warning me-2"></i>Panel de Administración</h2>
            <p class="text-muted mb-0 text-white-50">Bienvenido al sistema de administración de Ferretería ProAva</p>
        </div>
        <div>
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                <i class="bi bi-shield-lock-fill me-1"></i> Perfil: Administrador
            </span>
        </div>
    </div>

    <!-- Stat Cards Row -->
    <div class="row g-4 mb-4">
        <!-- Total Users Stat -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-primary">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Usuarios Registrados</span>
                            <h3 class="fw-bold mt-2 mb-0 text-primary">@ViewBag.TotalUsuarios</h3>
                        </div>
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                            <i class="bi bi-people-fill fs-2 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Products Stat -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-success">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Catálogo de Productos</span>
                            <h3 class="fw-bold mt-2 mb-0 text-success">@ViewBag.TotalProductos</h3>
                        </div>
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <i class="bi bi-box-seam-fill fs-2 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Low Stock Stat -->
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-danger">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="text-muted fw-semibold text-uppercase small">Alerta Stock Bajo</span>
                            <h3 class="fw-bold mt-2 mb-0 text-danger">@ViewBag.StockBajo</h3>
                        </div>
                        <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                            <i class="bi bi-exclamation-triangle-fill fs-2 text-danger"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Access Modules Row -->
    <div class="row g-4">
        <!-- User Management Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-primary text-white p-3 me-3">
                            <i class="bi bi-person-gear fs-3"></i>
                        </div>
                        <div>
                            <h4 class="card-title fw-bold mb-1">Gestión de Usuarios</h4>
                            <p class="card-text text-muted mb-0">Consulte, active/desactive cuentas de usuarios y modifique roles del sistema.</p>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i> Control de permisos</small>
                        <a asp-controller="Usuario" asp-action="ConsultarUsuarios" class="btn btn-primary px-3">
                            <i class="bi bi-arrow-right-circle me-1"></i> Administrar
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Management Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-success text-white p-3 me-3">
                            <i class="bi bi-tools fs-3"></i>
                        </div>
                        <div>
                            <h4 class="card-title fw-bold mb-1">Gestión de Productos</h4>
                            <p class="card-text text-muted mb-0">Mantenimiento de inventario ferretero, agregar artículos, precios y stock.</p>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-box me-1"></i> Control de inventario</small>
                        <a asp-controller="Producto" asp-action="ConsultarProductosAdmin" class="btn btn-success px-3">
                            <i class="bi bi-arrow-right-circle me-1"></i> Administrar
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Management Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-info text-white p-3 me-3">
                            <i class="bi bi-tags-fill fs-3"></i>
                        </div>
                        <div>
                            <h4 class="card-title fw-bold mb-1">Gestión de Categorías</h4>
                            <p class="card-text text-muted mb-0">Organice el catálogo creando y clasificando las categorías ferreteras.</p>
                        </div>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-tag me-1"></i> Clasificación de catálogo</small>
                        <a asp-controller="Producto" asp-action="ConsultarCategorias" class="btn btn-info text-white px-3">
                            <i class="bi bi-arrow-right-circle me-1"></i> Administrar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
