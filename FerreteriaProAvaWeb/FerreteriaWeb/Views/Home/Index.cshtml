@model List<FerreteriaWeb.Models.ProductoModel>

@using FerreteriaWeb.Helpers
@using FerreteriaWeb.Models

@{
    ViewData["Title"] = "Inicio";

    var carrito = Context.Session.GetObject<CarritoModel>("Carrito") ?? new CarritoModel();
    var cantidad = carrito.Items.Sum(x => x.Cantidad);
}

    <!-- Offer Start -->
    <div class="container-fluid pt-5 pb-3">
        <div class="row px-xl-5">
            <div class="col-md-12">
                <div class="product-offer mb-30" style="height: 300px;">
                    <img class="img-fluid" src="~/img/offer-1.jpg" alt="">
                    <div class="offer-text">
                        <h6 class="text-white text-uppercase">Descuento 20%</h6>
                        <h3 class="text-white mb-3">Promoción del Mes</h3>
                        <a href="" class="btn btn-primary">Ver descuentos</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Offer End -->
    <!-- Products destacados Start -->
    <div class="container-fluid pt-5 pb-3">
        <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4">
            <span class="bg-secondary pr-3">Productos Destacados</span>
        </h2>

        <div class="row px-xl-3">

            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-3 pb-4">
                    <div class="product-item bg-light h-100">

                        <div class="d-flex justify-content-center align-items-center p-3"
                             style="height:150px;">

                            <img src="~/img/productos destacados/@item.Imagen"
                                 class="img-fluid"
                                 style="max-height:100px; max-width:100%; object-fit:contain;"
                                 alt="@item.Nombre" />

                        </div>

                        <div class="text-center py-3 px-2">

                            <h6 class="text-truncate">
                                @item.Nombre
                            </h6>

                            <div class="d-flex justify-content-center mt-2">
                                <h5>₡ @item.Precio.ToString("N2")</h5>
                            </div>

                            <div class="mt-3">
                                <a asp-controller="Producto"
                                   asp-action="Detalle"
                                   asp-route-id="@item.IdProducto"
                                   class="btn btn-outline-primary">
                                    <i class="fa fa-eye"></i> Ver
                                </a>

                                <div class="d-flex align-items-center justify-content-center gap-2 mt-3">

                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm"
                                            onclick="cambiarCantidad(@item.IdProducto,-1)">
                                        -
                                    </button>

                                    <input type="number"
                                           id="cantidad_@item.IdProducto"
                                           value="1"
                                           min="1"
                                           class="form-control text-center"
                                           style="width:60px;" />

                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm"
                                            onclick="cambiarCantidad(@item.IdProducto,1)">
                                        +
                                    </button>

                                </div>

                                <form asp-controller="Carrito"
                                      asp-action="Agregar"
                                      method="post"
                                      class="mt-2">

                                    <input type="hidden"
                                           name="id"
                                           value="@item.IdProducto" />

                                    <input type="hidden"
                                           id="cantidadHidden_@item.IdProducto"
                                           name="cantidad"
                                           value="1" />

                                    <button class="btn btn-warning w-100">

                                        <i class="fa fa-shopping-cart"></i>
                                        Agregar

                                    </button>

                                </form>
                            </div>
                         

                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
    <!-- Products End -->
    
    
    <!-- Categorías Start -->
    <div class="container-fluid pt-5">
        <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">Categorías Principales</span></h2>
        <div class="row px-xl-5 pb-3">
            <div class="col-lg-3 col-md-4 col-sm-6 pb-1">
