@model IEnumerable<FerreteriaWeb.Models.ProductoModel>

@{
    ViewData["Title"] = "Gestión de Productos";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Header Breadcrumb & Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Administración</a></li>
                    <li class="breadcrumb-item active">Productos</li>
                </ol>
            </nav>
            <h3 class="fw-bold m-0"><i class="bi bi-tools text-success me-2"></i>Catálogo & Inventario de Productos</h3>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Volver al Panel
            </a>
            <a asp-controller="Producto" asp-action="RegistrarProducto" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Nuevo Producto
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-secondary">Mantenimiento de Catálogo Ferretero</h5>
            <span class="badge bg-success rounded-pill">Total: @Model.Count() productos</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>SKU</th>
                            <th>Nombre del Producto</th>
                            <th>Precio Unitario</th>
                            <th>Stock Actual</th>
                            <th>Categoría</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="bi bi-box-seam fs-2 d-block mb-2"></i>
                                    No hay productos registrados en el inventario.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var p in Model)
                            {
                                bool bajoStock = p.StockActual <= p.StockMinimo;
                                <tr>
                                    <td class="ps-4 fw-semibold">#@p.IdProducto</td>
                                    <td><code class="bg-light text-dark px-2 py-1 rounded border">@(string.IsNullOrEmpty(p.SKU) ? "N/A" : p.SKU)</code></td>
                                    <td class="fw-bold">@p.Nombre</td>
                                    <td class="text-success fw-bold">₡@p.Precio.ToString("N2")</td>
                                    <td>
                                        @if (bajoStock)
                                        {
                                            <span class="badge bg-danger px-2 py-1" title="Stock por debajo o igual al mínimo recomendando (@p.StockMinimo)">
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i> @p.StockActual unidades (Bajo)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border px-2 py-1">
                                                @p.StockActual unidades
                                            </span>
                                        }
                                    </td>
                                    <td><span class="badge bg-info-subtle text-info border border-info-subtle">@(string.IsNullOrEmpty(p.NombreCategoria) ? "General" : p.NombreCategoria)</span></td>
                                    <td>
                                        @if (p.Estado)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2 border border-success-subtle rounded-pill">
                                                <i class="bi bi-check-circle me-1"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary px-3 py-2 border border-secondary-subtle rounded-pill">
                                                <i class="bi bi-eye-slash me-1"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="EditarProducto" asp-route-idProducto="@p.IdProducto" class="btn btn-sm btn-outline-primary" title="Editar Producto">
                                                <i class="bi bi-pencil-square"></i> Editar
                                            </a>
                                            <form asp-action="CambiarEstadoProducto" method="post" class="d-inline">
                                                <input type="hidden" name="idProducto" value="@p.IdProducto" />
                                                @if (p.Estado)
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Desactivar producto">
                                                        <i class="bi bi-pause-circle"></i> Inactivar
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Activar producto">
                                                        <i class="bi bi-play-circle"></i> Activar
                                                    </button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
