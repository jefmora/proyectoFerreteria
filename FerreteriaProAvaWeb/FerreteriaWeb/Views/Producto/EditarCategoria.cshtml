@model FerreteriaWeb.Models.CategoriaModel

@{
    ViewData["Title"] = "Editar Categoría";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1">
                            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Administración</a></li>
                            <li class="breadcrumb-item"><a asp-controller="Producto" asp-action="ConsultarCategorias">Categorías</a></li>
                            <li class="breadcrumb-item active">Editar</li>
                        </ol>
                    </nav>
                    <h3 class="fw-bold m-0"><i class="bi bi-pencil-square text-primary me-2"></i>Editar Categoría</h3>
                </div>
                <a asp-action="ConsultarCategorias" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>

            @if (ViewBag.MensajeError != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-tag me-2"></i>Información de la Categoría</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditarCategoria" method="post">
                        <input type="hidden" asp-for="IdCategoria" />
                        <input type="hidden" asp-for="Estado" />

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold">Nombre de la Categoría <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej. Cerrajería & Candados" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-semibold">Descripción (Opcional)</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Ej. Cerraduras, llaves, pasadores y accesorios de seguridad"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="ConsultarCategorias" class="btn btn-light border px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-1"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
