@model FerreteriaWeb.Models.ProductoModel

@{
    ViewData["Title"] = "Detalle del Producto";
}

<div class="container-fluid py-5">

    <div class="container">

        <div class="card border-0 shadow">

            <div class="row g-0">

                <!-- Imagen -->
                <div class="col-lg-5">

                    <div class="bg-light d-flex justify-content-center align-items-center h-100 p-5">

                        <img src="~/img/productos destacados/@Model.Imagen"
                             class="img-fluid product-image"
                             alt="@Model.Nombre" />

                    </div>

                </div>

                <!-- Información -->
                <div class="col-lg-7">

                    <div class="p-5">

                        <span class="badge bg-warning text-dark mb-3 px-3 py-2">
                            @Model.Categoria
                        </span>

                        <h2 class="fw-bold mb-3">
                            @Model.Nombre
                        </h2>

                        <h1 class="text-warning fw-bold mb-4">
                            ₡ @Model.Precio.ToString("N2")
                        </h1>

                        <p class="text-muted mb-4">
                            @Model.Descripcion
                        </p>

                        <hr />

                        <div class="mb-4">

                            @if (Model.StockActual > 0)
                            {
                                <span class="text-success fw-bold">
                                    <i class="fa fa-check-circle"></i>
                                    Disponible (@Model.StockActual unidades)
                                </span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">
                                    <i class="fa fa-times-circle"></i>
                                    Agotado
                                </span>
                            }

                        </div>

                        <div class="d-flex align-items-center gap-3 mt-4">

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="cambiarCantidad(-1)">
                                -
                            </button>

                            <input type="number"
                                   id="cantidad"
                                   value="1"
                                   min="1"
                                   class="form-control text-center"
                                   style="width:70px;" />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="cambiarCantidad(1)">
                                +
                            </button>

                            <form asp-controller="Carrito"
                                  asp-action="Agregar"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@Model.IdProducto" />

                                <input type="hidden"
                                       id="cantidadHidden"
                                       name="cantidad"
                                       value="1" />

                                <button type="submit"
                                        class="btn btn-warning btn-lg">

                                    <i class="fa fa-shopping-cart"></i>
                                    Agregar al carrito

                                </button>

                            </form>

                            <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-dark btn-lg">

                                Volver

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .product-image {
        max-height: 420px;
        transition: .3s;
    }

        .product-image:hover {
            transform: scale(1.08);
        }

    .card {
        border-radius: 18px;
    }

    .btn-warning {
        font-weight: 600;
    }

</style>
<script>

    function cambiarCantidad(valor) {

        let txt = document.getElementById("cantidad");
        let hidden = document.getElementById("cantidadHidden");

        let cantidad = parseInt(txt.value) + valor;

        if (cantidad < 1)
            cantidad = 1;

        txt.value = cantidad;
        hidden.value = cantidad;
    }

</script>
