@model List<FerreteriaWeb.Models.ProductoModel>

@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-4">

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">

                <div class="card">

                    <div class="card-body">

                        <h5>@item.Nombre</h5>

                        <h4>₡ @item.Precio.ToString("N2")</h4>

                        <p>Stock: @item.StockActual</p>

                        <a asp-controller="Carrito"
                           asp-action="Agregar"
                           asp-route-idProducto="@item.IdProducto"
                           class="btn btn-primary w-100">
                            Agregar al carrito
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>