@model FerreteriaWeb.Models.UsuarioModel

@{
    ViewData["Title"] = "Login";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/page-auth.css">
    <link rel="stylesheet" href="~/css/core.css">
}

<div class="container-xxl">
    <div class="authentication-wrapper authentication-basic container-p-y">
        <div class="authentication-inner">

            <div class="card px-sm-6 px-0">
                <div class="card-body">

                    <!-- Logo -->
                    <div class="app-brand justify-content-center mb-6">
                        <a href="/" class="app-brand-link gap-2">
                            <span class="app-brand-logo demo">
                            </span>
                            <span class="app-brand-text demo text-heading fw-bold">
                                Proyecto Ferreteria
                            </span>
                        </a>
                    </div>

                    <!-- Título -->
                    <h4 class="mb-1">Bienvenido</h4>
                    <p class="mb-6">
                        Inicia sesión para acceder al sistema.
                    </p>

                    <!-- Alerta de Error -->
                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger text-center mb-4" role="alert">
                            @ViewBag.Mensaje
                        </div>
                    }

                    <!-- Formulario -->
                    <form id="formAuthentication" class="mb-6" asp-controller="Auth" asp-action="LoginBasic" method="post">

                        <div class="mb-6">
                            <label class="form-label" asp-for="CorreoElectronico">Correo Electrónico</label>
                            <input asp-for="CorreoElectronico"
                                   type="email"
                                   class="form-control"
                                   placeholder="Ingrese su correo"
                                   required
                                   autofocus />
                        </div>

                        <div class="mb-6">
                            <label class="form-label" asp-for="Contrasenna">Contraseña</label>
                            <input asp-for="Contrasenna"
                                   type="password"
                                   class="form-control"
                                   placeholder="Ingrese su contraseña"
                                   required />
                        </div>

                        <button type="submit" class="btn btn-primary d-grid w-100">
                            Ingresar
                        </button>

                    </form>

                    <!-- Registro -->
                    <p class="text-center">
                        <span>¿No tienes una cuenta?</span>
                        <a asp-controller="Auth"
                           asp-action="RegisterBasic">
                            <span>Regístrate aquí</span>
                        </a>
                    </p>

                    <!-- Olvido Contraseña -->
                    <div class="mb-4 text-center">
                        <a asp-controller="Auth"
                           asp-action="ForgotPassword">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>