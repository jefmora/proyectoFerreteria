@model FerreteriaWeb.Models.UsuarioModel

@{
    ViewData["Title"] = "Registro de Usuario";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/page-auth.css">
    <link rel="stylesheet" href="~/css/core.css">
}

<div class="container-xxl">
    <div class="authentication-wrapper authentication-basic container-p-y">
        <div class="authentication-inner">
            <!-- Register Card -->
            <div class="card px-sm-6 px-0">
                <div class="card-body">
                    <!-- Logo -->
                    <div class="app-brand justify-content-center mb-6">
                        <a href="/" class="app-brand-link gap-2">
                            <span class="app-brand-logo demo">@await Html.PartialAsync("../Parciales/_Macros")</span>
                            <span class="app-brand-text demo text-heading fw-bold">@TempData.Peek("appName")</span>
                        </a>
                    </div>
                    <!-- /Logo -->
                    <h4 class="mb-1">¡Crea tu cuenta! 🚀</h4>
                    <p class="mb-6">Ingresa tus datos para registrarte en el sistema.</p>

                    <!-- Alerta de Error (Si la API devuelve BadRequest) -->
                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger text-center mb-4" role="alert">
                            @ViewBag.Mensaje
                        </div>
                    }

                    <form id="formAuthentication" class="mb-6" asp-controller="Auth" asp-action="RegisterBasic" method="POST">


                        <div class="mb-6">
                            <label asp-for="Identificacion" class="form-label">Identificación / Cédula</label>
                            <input asp-for="Identificacion"
                                   type="text"
                                   class="form-control"
                                   placeholder="Ingrese su número de identificación"
                                   maxlength="15"
                                   required
                                   autofocus />
                        </div>

                        <div class="mb-6">
                            <label asp-for="Nombre" class="form-label">Nombre Completo</label>
                            <input asp-for="Nombre"
                                   type="text"
                                   class="form-control"
                                   placeholder="Ingrese su nombre completo"
                                   maxlength="250"
                                   required />
                        </div>

                        <div class="mb-6">
                            <label asp-for="CorreoElectronico" class="form-label">Correo Electrónico</label>
                            <input asp-for="CorreoElectronico"
                                   type="email"
                                   class="form-control"
                                   placeholder="correo@ejemplo.com"
                                   maxlength="100"
                                   required />
                        </div>

                        <div class="form-password-toggle mb-6">
                            <label asp-for="Contrasenna" class="form-label">Contraseña</label>
                            <div class="input-group input-group-merge">
                                <input asp-for="Contrasenna"
                                       type="password"
                                       class="form-control"
                                       placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;"
                                       maxlength="100"
                                       required />
                                <span class="input-group-text cursor-pointer"><i class="icon-base bx bx-hide"></i></span>
                            </div>
                        </div>

                        <div class="my-7">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="terms-conditions" name="terms" required />
                                <label class="form-check-label" for="terms-conditions">
                                    Acepto los
                                    <a href="javascript:void(0);">términos y condiciones</a>
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary d-grid w-100">Registrarse</button>
                    </form>

                    <p class="text-center">
                        <span>¿Ya tienes una cuenta?</span>
                        <a asp-controller="Auth" asp-action="LoginBasic">
                            <span>Iniciar sesión aquí</span>
                        </a>
                    </p>

                </div>
            </div>
            <!-- Register Card -->
        </div>
    </div>
</div>
