@model FerreteriaWeb.Models.UsuarioModel

@{
    ViewData["Title"] = "Recuperar Contraseña";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/page-auth.css">
    <link rel="stylesheet" href="~/css/core.css">
}

@* ************** Content ************** *@
<div class="container-xxl">
    <div class="authentication-wrapper authentication-basic container-p-y">
        <div class="authentication-inner">
            <!-- Forgot Password -->
            <div class="card px-sm-6 px-0">
                <div class="card-body">
                    <!-- Logo -->
                    <div class="app-brand justify-content-center mb-6">
                        <a href="/" class="app-brand-link gap-2">
                            <span class="app-brand-logo demo">@await Html.PartialAsync("../Parciales/_Macros")</span>
                            <span class="app-brand-text demo text-heading fw-bold">@TempData.Peek("appName")</span>
                        </a>
                    </div>
                    <!-- /Logo -->
                    <h4 class="mb-1">¿Olvidaste tu contraseña? 🔒</h4>
                    <p class="mb-6">Ingresa tu correo y te enviaremos las instrucciones para la debida recuperación.</p>

                    <!-- Alerta de Error (Si la API devuelve BadRequest o NotFound) -->
                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger text-center mb-4" role="alert">
                            @ViewBag.Mensaje
                        </div>
                    }

                    <form id="formAuthentication" class="mb-6" asp-controller="Auth" asp-action="ForgotPassword" method="POST">
                        <div class="mb-6">
                            <label asp-for="CorreoElectronico" class="form-label">Correo Electrónico</label>
                            <input asp-for="CorreoElectronico"
                                   type="email"
                                   class="form-control"
                                   placeholder="Ingresa tu correo electrónico"
                                   required
                                   autofocus />
                        </div>
                        <button type="submit" class="btn btn-primary d-grid w-100">Enviar enlace de recuperación</button>
                    </form>

                    <div class="text-center">
                        <a asp-action="LoginBasic" asp-controller="Auth" class="d-flex justify-content-center align-items-center">
                            <i class="icon-base bx bx-chevron-left me-1"></i>
                            Volver al inicio de sesión
                        </a>
                    </div>
                </div>
            </div>
            <!-- /Forgot Password -->
        </div>
    </div>
</div>
