@model FerreteriaWeb.Models.CarritoModel

<h2>Carrito de Compras</h2>
<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                <i class="bi bi-cart3"></i> Mi carrito
            </h2>

            <p class="text-muted mb-0">
                @Model.Items.Count producto(s) en el carrito
            </p>
        </div>

    </div>


@if (Model.Items.Count == 0)
{
    <div class="alert alert-warning">
        El carrito está vacío.
    </div>
}
else
{
        <table class="table table-hover align-middle shadow">

            <thead style="background:#FFD333;color:#2B2E4A;" class="text-center">
                <tr>
                    <th>Producto</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                    <th>Total</th>
                    <th>Acciones</th>
                </tr>
            </thead>

        <tbody>

            @foreach (var item in Model.Items)
            {
                <tr>

                        <td class="align-middle">

                            <div class="d-flex align-items-center">

                                <img src="~/img/productos destacados/@item.Producto.Imagen"
                                     class="rounded border me-3"
                                     style="width:80px;height:80px;object-fit:contain;background:white;" />

                                <div>

                                    <h6 class="mb-1 fw-bold">
                                        @item.Producto.Nombre
                                    </h6>

                                    <small class="text-muted">
                                        @item.Producto.Categoria
                                    </small>

                                </div>

                            </div>

                        </td>

                        <td class="text-center">
                            ₡ @item.Producto.Precio.ToString("N2")
                        </td>

                        <td class="text-center">
                            @item.Cantidad
                        </td>

                        <td class="text-center fw-bold text-success">
                            ₡ @item.Total.ToString("N2")
                        </td>

                        <td class="text-center">
                            <a asp-action="Disminuir"
                               asp-route-id="@item.Producto.IdProducto"
                               class="btn btn-outline-warning btn-sm">

                                <i class="fa fa-minus"></i>
                                 - 

                            </a>

                            <a asp-action="Aumentar"
                               asp-route-id="@item.Producto.IdProducto"
                               class="btn btn-warning btn-sm">

                                <i class="fa fa-plus"></i>
                                 + 

                            </a>

                            <a asp-action="Eliminar"
                               asp-route-id="@item.Producto.IdProducto"
                               class="btn btn-outline-danger btn-sm">

                                <i class="fa fa-trash"></i>
                                Eliminar

                            </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

        <div class="card shadow border-0 mt-4">

            <div class="card-header bg-warning">

                <h5 class="mb-0 fw-bold">
                    Resumen del pedido
                </h5>

            </div>

            <div class="card-body">

                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal</span>
                    <strong>₡ @Model.Subtotal.ToString("N2")</strong>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>IVA</span>
                    <strong>₡ @Model.IVA.ToString("N2")</strong>
                </div>

                <hr>

                <div class="d-flex justify-content-between">

                    <h4>Total</h4>

                    <h4 class="text-warning">
                        ₡ @Model.Total.ToString("N2")
                    </h4>

                </div>

            </div>

        </div>
        <div class="mt-4 d-flex justify-content-between">

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-dark btn-lg">

                <i class="fa fa-arrow-left"></i>
                Seguir comprando

            </a>

            <div>

                <a asp-action="Vaciar"
                   class="btn btn-outline-danger btn-lg"
                   onclick="return confirm('¿Desea vaciar el carrito?');">

                    <i class="fa fa-trash"></i>
                    Vaciar

                </a>

                <a class="btn btn-warning btn-lg ms-2">

                    <i class="fa fa-credit-card"></i>
                    Finalizar compra

                </a>

            </div>

        </div>

    }
</div>