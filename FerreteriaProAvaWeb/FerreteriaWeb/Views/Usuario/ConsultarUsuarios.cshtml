@model IEnumerable<FerreteriaWeb.Models.UsuarioModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Header Breadcrumb & Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Administración</a></li>
                    <li class="breadcrumb-item active">Usuarios</li>
                </ol>
            </nav>
            <h3 class="fw-bold m-0"><i class="bi bi-people-fill text-primary me-2"></i>Gestión de Usuarios</h3>
        </div>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver al Panel
        </a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-secondary">Lista de Usuarios Registrados</h5>
            <span class="badge bg-primary rounded-pill">Total: @Model.Count() usuarios</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Identificación</th>
                            <th>Nombre Completo</th>
                            <th>Correo Electrónico</th>
                            <th>Rol Asignado</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                                    No hay usuarios registrados en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var u in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">#@u.Consecutivo</td>
                                    <td><span class="badge bg-light text-dark border">@u.Identificacion</span></td>
                                    <td class="fw-bold">@u.Nombre</td>
                                    <td>@u.CorreoElectronico</td>
                                    <td>
                                        <form asp-action="CambiarRolUsuario" method="post" class="d-inline-flex align-items-center gap-1">
                                            <input type="hidden" name="consecutivo" value="@u.Consecutivo" />
                                            <select name="consecutivoRol" class="form-select form-select-sm border-secondary-subtle" onchange="this.form.submit()">
                                                <!option value="1" @(u.ConsecutivoRol == 1 ? "selected" : "")>Administrador</!option>
                                                <!option value="2" @(u.ConsecutivoRol == 2 ? "selected" : "")>Usuario</!option>
                                            </select>
                                        </form>
                                    </td>
                                    <td>
                                        @if (u.Estado)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2 border border-success-subtle rounded-pill">
                                                <i class="bi bi-check-circle me-1"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2 border border-danger-subtle rounded-pill">
                                                <i class="bi bi-x-circle me-1"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="CambiarEstadoUsuario" method="post" class="d-inline">
                                            <input type="hidden" name="consecutivo" value="@u.Consecutivo" />
                                            @if (u.Estado)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar cuenta de usuario">
                                                    <i class="bi bi-slash-circle me-1"></i> Desactivar
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Activar cuenta de usuario">
                                                    <i class="bi bi-check2-circle me-1"></i> Activar
                                                </button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
